# Copy to agent-service/.env and adjust. .env is git-ignored.

# Hugging Face cache. Point at a SHARED cache to avoid re-downloading the ~8GB model.
# Must be set BEFORE transformers is imported — the app loads this .env first.
HF_HOME=./.hf_cache

# Model (Gemma 4 12B, instruction-tuned).
MODEL_ID=google/gemma-4-12B-it

# --- vLLM backend ---
# The checkpoint vllm serves. MUST be the same string for the server and the gateway;
# keeping it in .env guarantees that. For a 16GB GPU use a w4a16 QAT checkpoint:
VLLM_MODEL_ID=google/gemma-4-E4B-it-qat-w4a16-ct
# Where the gateway reaches the model server (default already points here):
VLLM_BASE_URL=http://127.0.0.1:8001/v1

# Optional: only helps with HF download rate limits (model is not gated).
# HF_TOKEN=hf_xxx

# Generation defaults for the concierge chat.
MAX_NEW_TOKENS=1024
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.95
