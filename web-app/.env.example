# Copy to web-app/.env and adjust as needed. All optional — sensible defaults apply.

# Bind address for this app.
WEB_HOST=0.0.0.0
WEB_PORT=8090

# UI language.
UI_LANGUAGE=ja

# Override only if the repo layout differs from the default (web-app/ sibling of docs/).
# PROFILES_DIR=/abs/path/to/docs/profiles
# DATA_DIR=/abs/path/to/DATA
