# Copy to web-app/.env and adjust as needed. All optional — sensible defaults apply.

# Bind address for this app.
WEB_HOST=0.0.0.0
WEB_PORT=8090

# UI language.
UI_LANGUAGE=ja

# Agent-service web API (agent.api) that answers concierge chat. The web-app proxies
# chat to it server-side, so the key stays off the browser. Leave the key empty if the
# agent-service runs unauthenticated (dev); set it to match GOTOAI_AGENT_API_KEY there.
AGENT_API_URL=http://127.0.0.1:8000
GOTOAI_AGENT_API_KEY=
# AGENT_TIMEOUT=120

# Override only if the repo layout differs from the default (web-app/ sibling of docs/).
# PROFILES_DIR=/abs/path/to/docs/profiles
# DATA_DIR=/abs/path/to/DATA
